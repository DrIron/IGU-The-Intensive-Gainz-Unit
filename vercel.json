{
  "crons": [
    { "path": "/api/cron?fn=send-admin-daily-summary",        "schedule": "0 6 * * *" },
    { "path": "/api/cron?fn=send-weekly-coach-digest",         "schedule": "0 7 * * 1" },
    { "path": "/api/cron?fn=process-renewal-reminders",        "schedule": "0 8 * * *" },
    { "path": "/api/cron?fn=process-coach-inactivity-monitor", "schedule": "30 8 * * *" },
    { "path": "/api/cron?fn=process-testimonial-requests",     "schedule": "0 9 * * 1" },
    { "path": "/api/cron?fn=process-referral-reminders",       "schedule": "0 9 * * 1" },
    { "path": "/api/cron?fn=process-payment-failure-drip",     "schedule": "30 9 * * *" },
    { "path": "/api/cron?fn=process-abandoned-onboarding",     "schedule": "0 10 * * *" },
    { "path": "/api/cron?fn=process-inactive-client-alerts",   "schedule": "30 10 * * *" },
    { "path": "/api/cron?fn=process-lead-nurture",             "schedule": "0 11 * * *" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://i.ytimg.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.tap.company https://challenges.cloudflare.com https://*.sentry.io; frame-src https://challenges.cloudflare.com https://checkout.tap.company https://www.youtube.com; object-src 'none'; base-uri 'self'"
        }
      ]
    }
  ]
}
